{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yeetrun/yeet-vm-images/schemas/guest-base-manifest.schema.json",
  "title": "Yeet VM guest base manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "guest_base_id", "os", "os_version", "architecture", "rootfs", "default_kernel_channel", "provenance"],
  "properties": {
    "schema_version": { "const": 1 },
    "guest_base_id": { "type": "string", "pattern": "^guest-(ubuntu|nixos)-[0-9]+[.][0-9]+-amd64-v[1-9][0-9]*$" },
    "os": { "enum": ["ubuntu", "nixos"] },
    "os_version": { "type": "string", "pattern": "^[0-9]+[.][0-9]+$" },
    "architecture": { "const": "amd64" },
    "rootfs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256", "uncompressed_bytes"],
      "properties": {
        "url": { "type": "string", "pattern": "^https://github[.]com/yeetrun/yeet-vm-images/releases/download/guest-(ubuntu|nixos)-[0-9]+[.][0-9]+-amd64-v[1-9][0-9]*/rootfs[.]ext4[.]zst$" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "uncompressed_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "default_kernel_channel": { "enum": ["stable", "candidate"] },
    "provenance": { "$ref": "#/$defs/provenance" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_commit", "workflow_run_url"],
      "properties": {
        "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "workflow_run_url": { "type": "string", "pattern": "^https://github[.]com/yeetrun/yeet-vm-images/actions/runs/[1-9][0-9]*$" }
      }
    }
  }
}
