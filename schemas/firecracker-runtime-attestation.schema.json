{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yeetrun/yeet-vm-images/schemas/firecracker-runtime-attestation.schema.json",
  "title": "Firecracker runtime attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "subject",
    "runner",
    "source",
    "tested_yeet",
    "artifacts",
    "matrix",
    "started_at",
    "completed_at",
    "result"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "kind": {
      "enum": [
        "integration",
        "canary"
      ]
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_id",
        "manifest_sha256"
      ],
      "properties": {
        "runtime_id": {
          "type": "string",
          "pattern": "^firecracker-v[0-9]+[.][0-9]+[.][0-9]+-yeet-v[1-9][0-9]*$"
        },
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "architecture"
      ],
      "properties": {
        "class": {
          "const": "self-hosted-linux-kvm"
        },
        "architecture": {
          "const": "amd64"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit",
        "workflow_run"
      ],
      "properties": {
        "repository": {
          "const": "yeetrun/yeet-vm-images"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "workflow_run": {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        }
      }
    },
    "tested_yeet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "commit"
      ],
      "properties": {
        "repository": {
          "const": "yeetrun/yeet"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ubuntu_guest_release",
        "nixos_guest_release",
        "current_kernel_release",
        "previous_kernel_release"
      ],
      "properties": {
        "ubuntu_guest_release": {
          "type": "string",
          "pattern": "^guest-ubuntu-[0-9]+[.][0-9]+-amd64-v[1-9][0-9]*$"
        },
        "nixos_guest_release": {
          "type": "string",
          "pattern": "^guest-nixos-[0-9]+[.][0-9]+-amd64-v[1-9][0-9]*$"
        },
        "current_kernel_release": {
          "type": "string",
          "pattern": "^kernel-linux-[0-9]+[.][0-9]+([.][0-9]+)*-yeet-v[1-9][0-9]*$"
        },
        "previous_kernel_release": {
          "type": "string",
          "pattern": "^kernel-linux-[0-9]+[.][0-9]+([.][0-9]+)*-yeet-v[1-9][0-9]*$"
        }
      }
    },
    "matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ubuntu",
        "nixos",
        "current_kernel",
        "previous_kernel",
        "raw",
        "zfs",
        "custom_roots",
        "jailer_drop"
      ],
      "properties": {
        "ubuntu": {
          "const": "passed"
        },
        "nixos": {
          "const": "passed"
        },
        "current_kernel": {
          "const": "passed"
        },
        "previous_kernel": {
          "const": "passed"
        },
        "raw": {
          "const": "passed"
        },
        "zfs": {
          "const": "passed"
        },
        "custom_roots": {
          "const": "passed"
        },
        "jailer_drop": {
          "const": "passed"
        }
      }
    },
    "canary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boot_cycles",
        "natural_reboots",
        "disk_restore_cycles",
        "soak_seconds",
        "runtime_upgrade",
        "runtime_trial",
        "runtime_fallback",
        "runtime_rollback",
        "kernel_sync_current",
        "kernel_sync_previous",
        "networking",
        "catch_restart",
        "interrupted_transaction_recovery",
        "emergency_override",
        "emergency_approver",
        "emergency_reason"
      ],
      "properties": {
        "boot_cycles": {
          "type": "integer",
          "minimum": 25
        },
        "natural_reboots": {
          "type": "integer",
          "minimum": 10
        },
        "disk_restore_cycles": {
          "type": "integer",
          "minimum": 5
        },
        "soak_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "runtime_upgrade": { "const": "passed" },
        "runtime_trial": { "const": "passed" },
        "runtime_fallback": { "const": "passed" },
        "runtime_rollback": { "const": "passed" },
        "kernel_sync_current": { "const": "passed" },
        "kernel_sync_previous": { "const": "passed" },
        "networking": { "const": "passed" },
        "catch_restart": { "const": "passed" },
        "interrupted_transaction_recovery": { "const": "passed" },
        "emergency_override": { "type": "boolean" },
        "emergency_approver": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "emergency_reason": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "emergency_override": { "const": true } },
            "required": ["emergency_override"]
          },
          "then": {
            "properties": {
              "emergency_approver": { "type": "string", "minLength": 1 },
              "emergency_reason": { "type": "string", "minLength": 1 }
            }
          },
          "else": {
            "properties": {
              "soak_seconds": { "minimum": 86400 },
              "emergency_approver": { "type": "null" },
              "emergency_reason": { "type": "null" }
            }
          }
        }
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "result": {
      "const": "passed"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "kind": { "const": "canary" } },
        "required": ["kind"]
      },
      "then": { "required": ["canary"] },
      "else": { "not": { "required": ["canary"] } }
    }
  ]
}
