{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yeetrun/yeet-vm-images/schemas/kernel-manifest.schema.json",
  "title": "Yeet VM kernel manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kernel_id", "upstream_version", "packaging_revision", "architecture", "vmlinux", "config", "guest_packages", "provenance"],
  "properties": {
    "schema_version": { "const": 1 },
    "kernel_id": { "$ref": "#/$defs/kernel_id" },
    "upstream_version": { "type": "string", "pattern": "^[0-9]+[.][0-9]+([.][0-9]+)*$" },
    "packaging_revision": { "type": "integer", "minimum": 1 },
    "architecture": { "const": "amd64" },
    "vmlinux": { "$ref": "#/$defs/vmlinux" },
    "config": { "$ref": "#/$defs/config" },
    "guest_packages": { "$ref": "#/$defs/guest_packages" },
    "provenance": { "$ref": "#/$defs/provenance" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "kernel_id": { "type": "string", "pattern": "^kernel-linux-[0-9]+[.][0-9]+([.][0-9]+)*-yeet-v[1-9][0-9]*$" },
    "vmlinux": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256"],
      "properties": {
        "url": { "type": "string", "pattern": "^https://github[.]com/yeetrun/yeet-vm-images/releases/download/kernel-linux-[0-9]+[.][0-9]+([.][0-9]+)*-yeet-v[1-9][0-9]*/vmlinux$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sha256"],
      "properties": {
        "url": { "type": "string", "pattern": "^https://github[.]com/yeetrun/yeet-vm-images/releases/download/kernel-linux-[0-9]+[.][0-9]+([.][0-9]+)*-yeet-v[1-9][0-9]*/kernel[.]config$" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "guest_packages": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalog_url", "selector_schema_version", "release_id"],
      "properties": {
        "catalog_url": { "const": "https://raw.githubusercontent.com/yeetrun/yeet-vm-images/main/kernel-packages/catalog.json" },
        "selector_schema_version": { "const": 2 },
        "release_id": { "$ref": "#/$defs/kernel_id" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_commit", "workflow_run_url"],
      "properties": {
        "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "workflow_run_url": { "type": "string", "pattern": "^https://github[.]com/yeetrun/yeet-vm-images/actions/runs/[1-9][0-9]*$" }
      }
    }
  }
}
